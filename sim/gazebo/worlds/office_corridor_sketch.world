    <!-- Start marker near the corridor bottom center, facing +Y. -->
    <model name="start_marker_flag">
      <static>true</static>
      <pose>-0.15 -5.65 0 0 0 1.57079632679</pose>
      <link name="pole">
        <visual name="pole_visual">
