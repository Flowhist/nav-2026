<?xml version="1.0"?>
<sdf version="1.7">
  <model name="whillcar">
    <self_collide>false</self_collide>

    <link name="base_link">
      <pose>0.225 0 0.25 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>40.0</mass>
        <inertia>
          <ixx>1.8646666667</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>4.6741666667</iyy>
          <iyz>0.0</iyz>
          <izz>4.5341666667</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.95 0.62 0.5</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <pose>0 0 0.09 0 0 0</pose>
        <geometry>
          <box>
            <size>0.95 0.62 0.5</size>
          </box>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.9 0.35</ambient>
          <diffuse>0.9 0.9 0.9 0.35</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel_link">
      <pose>0 0.25 0.145 1.57079632679 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.021025</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0125125</iyy>
          <iyz>0.0</iyz>
          <izz>0.0125125</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.145</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.145</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel_link">
      <pose>0 -0.25 0.145 1.57079632679 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.021025</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0125125</iyy>
          <iyz>0.0</iyz>
          <izz>0.0125125</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.145</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.145</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel_link</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel_link</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <link name="imu_link">
      <pose>0.16 0 0.35 0 0 0</pose>
      <visual name="imu_visual">
        <geometry>
          <box>
            <size>0.05 0.03 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.85 0.2 0.2 1.0</ambient>
          <diffuse>0.85 0.2 0.2 1.0</diffuse>
        </material>
      </visual>
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>100.0</update_rate>
        <topic>imu</topic>
        <enable_metrics>true</enable_metrics>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
    </joint>

    <link name="laser_frame">
      <pose>0.62 0.26 0.42 0 0 0</pose>
      <inertial>
        <mass>0.6</mass>
        <inertia>
          <ixx>0.000875</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.000875</iyy>
          <iyz>0.0</iyz>
          <izz>0.00075</izz>
        </inertia>
      </inertial>
      <collision name="laser_collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="laser_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.3 0.8 1.0</ambient>
          <diffuse>0.2 0.3 0.8 1.0</diffuse>
        </material>
      </visual>
      <sensor name="laser_sensor" type="gpu_lidar">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10.0</update_rate>
        <topic>scan</topic>
        <enable_metrics>true</enable_metrics>
        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.1415926</min_angle>
              <max_angle>3.1415926</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
      </sensor>
    </link>

    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>laser_frame</child>
    </joint>

    <link name="front_indicator_link">
      <pose>0 0 0.52 0 0 0</pose>
      <visual name="front_indicator_visual">
        <pose>0.19 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.38 0.02 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.85 0.2 0.2 1.0</ambient>
          <diffuse>0.85 0.2 0.2 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="front_indicator_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_indicator_link</child>
    </joint>

    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_radius>0.145</wheel_radius>
      <odom_publish_frequency>60.0</odom_publish_frequency>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <min_linear_acceleration>-2.0</min_linear_acceleration>
      <max_angular_acceleration>4.0</max_angular_acceleration>
      <min_angular_acceleration>-4.0</min_angular_acceleration>
      <max_linear_velocity>1.5</max_linear_velocity>
      <min_linear_velocity>-1.5</min_linear_velocity>
      <max_angular_velocity>2.5</max_angular_velocity>
      <min_angular_velocity>-2.5</min_angular_velocity>
      <topic>/model/finav_vehicle/cmd_vel</topic>
      <odom_topic>/model/finav_vehicle/odometry</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <plugin
      filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher"/>

    <plugin
      filename="ignition-gazebo-pose-publisher-system"
      name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>true</static_publisher>
      <static_update_frequency>1.0</static_update_frequency>
    </plugin>
  </model>
</sdf>
